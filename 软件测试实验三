import org.junit.jupiter.api.Test;
import static org.junit.jupiter.api.Assertions.*;

class PhoneBillTest {
    private final PhoneBill bill = new PhoneBill();

    // ========== 有效等价类 ==========
    // EC1：1分钟内（1~60秒）
    @Test
    void calculateFee_1Second() {
        assertEquals(0.05, bill.calculateFee(1));
    }

    @Test
    void calculateFee_60Seconds() {
        assertEquals(0.05, bill.calculateFee(60));
    }

    // EC2：1~20分钟
    @Test
    void calculateFee_20Minutes() {
        assertEquals(1.00, bill.calculateFee(1200));
    }

    // EC3：超过20分钟，≤30小时
    @Test
    void calculateFee_21Minutes() {
        assertEquals(1.10, bill.calculateFee(1260));
    }

    @Test
    void calculateFee_Max30Hours() {
        assertDoesNotThrow(() -> bill.calculateFee(108000));
    }

    // ========== 无效等价类 ==========
    // EC4：0秒
    @Test
    void calculateFee_0Second() {
        assertThrows(IllegalArgumentException.class, () -> bill.calculateFee(0));
    }

    // EC5：负数
    @Test
    void calculateFee_Negative() {
        assertThrows(IllegalArgumentException.class, () -> bill.calculateFee(-10));
    }

    // EC6：超过30小时
    @Test
    void calculateFee_Over30Hours() {
        assertThrows(IllegalArgumentException.class, () -> bill.calculateFee(108001));
    }
}
